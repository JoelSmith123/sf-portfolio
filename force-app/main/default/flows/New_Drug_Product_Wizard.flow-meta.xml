        <inputParameters>
            <name>productName</name>
            <value><elementReference>Field_ProductName</elementReference></value>
        </inputParameters>
        <inputParameters>
            <name>genericName</name>
            <value><elementReference>Field_GenericName</elementReference></value>
        </inputParameters>
        <inputParameters>
            <name>therapeuticArea</name>
            <value><elementReference>Field_TherapeuticArea</elementReference></value>
        </inputParameters>
        <inputParameters>
            <name>drugClassification</name>
            <value><elementReference>Field_DrugClassification</elementReference></value>
        </inputParameters>
        <inputParameters>
            <name>regulatoryStatus</name>
            <value><elementReference>Field_RegulatoryStatus</elementReference></value>
        </inputParameters>
        <inputParameters>
            <name>fdaApprovalDate</name>
            <value><elementReference>Field_FDAApprovalDate</elementReference></value>
        </inputParameters>
        <inputParameters>
            <name>launchDate</name>
            <value><elementReference>Field_LaunchDate</elementReference></value>
        </inputParameters>
        <inputParameters>
            <name>orphanDrugStatus</name>
            <value><elementReference>Field_OrphanDrug</elementReference></value>
        </inputParameters>
        <inputParameters>
            <name>manufacturer</name>
            <value><elementReference>Field_Manufacturer</elementReference></value>
        </inputParameters>
        <inputParameters>
            <name>ndcCode</name>
            <value><elementReference>Field_NDCCode</elementReference></value>
        </inputParameters>
        <inputParameters>
            <name>activeIngredients</name>
            <value><elementReference>Field_ActiveIngredients</elementReference></value>
        </inputParameters>
        <outputParameters>
            <assignToReference>varCreatedRecordId</assignToReference>
            <name>recordId</name>
        </outputParameters>
        <outputParameters>
            <assignToReference>varCreateSuccess</assignToReference>
            <name>success</name>
        </outputParameters>
        <outputParameters>
            <assignToReference>varCreateErrorMessage</assignToReference>
            <name>errorMessage</name>
        </outputParameters>
    </actionCalls>

    <!-- Search OpenFDA by brand name; exceptions are swallowed in Apex -->
    <actionCalls>
