    <!-- ─────────────────────────────────────────────────────────────
         DECISIONS (grouped, alpha by name)
         ───────────────────────────────────────────────────────────── -->
    <decisions>
        <name>Decision_CreateSuccess</name>
        <label>Record Created Successfully?</label>
        <locationX>176</locationX>
        <locationY>974</locationY>
        <defaultConnector>
            <targetReference>Screen_Error</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Creation failed</defaultConnectorLabel>
        <rules>
            <name>Outcome_CreateSuccess</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varCreateSuccess</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Screen_Success</targetReference>
            </connector>
            <label>Record created</label>
        </rules>
    </decisions>
    <decisions>
        <name>Decision_FDAFound</name>
        <label>FDA Data Found?</label>
        <locationX>176</locationX>
        <locationY>374</locationY>
        <defaultConnector>
            <targetReference>Screen_RegulatoryDetails</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No FDA data — skip preview</defaultConnectorLabel>
        <rules>
            <name>Outcome_FDAFound</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varFDAFound</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Screen_FDAPreview</targetReference>
            </connector>
            <label>FDA data found</label>
        </rules>
    </decisions>

    <!-- ─────────────────────────────────────────────────────────────
         FORMULAS — default values for pre-filled screen fields
         Evaluates acceptance checkboxes (set on Screen_FDAPreview);
         returns FDA value if accepted, else empty string.
         ───────────────────────────────────────────────────────────── -->
    <formulas>
        <name>formDefaultActiveIngredients</name>
        <dataType>String</dataType>
        <expression>IF({!Checkbox_AcceptActiveIngredients}, {!varFDAActiveIngredients}, "")</expression>
    </formulas>
    <formulas>
        <name>formDefaultManufacturer</name>
        <dataType>String</dataType>
        <expression>IF({!Checkbox_AcceptManufacturer}, {!varFDAManufacturer}, "")</expression>
    </formulas>
    <formulas>
        <name>formDefaultNDCCode</name>
        <dataType>String</dataType>
        <expression>IF({!Checkbox_AcceptNDC}, {!varFDANDCCode}, "")</expression>
    </formulas>

    <!-- ─────────────────────────────────────────────────────────────
         SCREENS (all grouped, in logical execution order)
         Note: standard screen fields do NOT use <outputParameters>.
         Their values are accessible via {!FieldName} in subsequent
         flow elements after the screen is completed.
         ───────────────────────────────────────────────────────────── -->

    <!-- Screen 1: Basic Information -->
    <screens>
