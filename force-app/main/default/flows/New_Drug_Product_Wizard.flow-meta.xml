<?xml version="1.0" encoding="UTF-8"?>
<!--
  Flow: New_Drug_Product_Wizard (Screen Flow)
  Type: Flow (manual launch — add to a Quick Action or utility bar)

  Execution path (connected via <connector> references):
    START
      → Screen_BasicInfo         (Step 1: Product Name, Generic Name, Therapeutic Area, Classification)
      → Action_SearchFDA         (invocable: search OpenFDA by brand name — exceptions swallowed)
      → Decision_FDAFound
            [found] → Screen_FDAPreview     (Step 2: review FDA data, tick acceptance checkboxes)
                    → Screen_RegulatoryDetails
          [default] → Screen_RegulatoryDetails
      → Screen_RegulatoryDetails (Step 3: Status, Dates, Orphan Drug, Manufacturer, NDC, Ingredients;
                                   manufacturer/NDC/ingredients pre-filled via formula if accepted)
      → Screen_Review            (Step 4: confirm all values before committing)
      → Action_CreateRecord      (invocable: DrugProductFlowController — catches DML errors)
      → Decision_CreateSuccess
            [success] → Screen_Success (terminal)
            [default] → Screen_Error   (terminal, Back allowed for retry)

  Key pattern: standard screen fields (InputField, DropdownBox, Boolean) do NOT use
  <outputParameters>. Their values are automatically accessible via {!FieldName} in
  subsequent elements. Only Apex action outputs need explicit <outputParameters>.
-->
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <description>Multi-step screen flow for creating a new Drug_Product__c record. Guides the user through basic info, an optional FDA data preview (DrugProductFDAFlowAction), regulatory details with FDA pre-filled defaults, and a review screen before committing via DrugProductFlowController. Demonstrates invocable Apex integration, conditional screen navigation, and formula-driven field defaults within a guided UI flow.</description>
    <interviewLabel>New Drug Product Wizard {!$Flow.CurrentDateTime}</interviewLabel>
    <label>New Drug Product Wizard</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>Flow</processType>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Screen_BasicInfo</targetReference>
        </connector>
    </start>
    <status>Active</status>

    <!-- ─────────────────────────────────────────────────────────────
