        <outputParameters>
            <assignToReference>varFDAFound</assignToReference>
            <name>found</name>
        </outputParameters>
        <outputParameters>
            <assignToReference>varFDAManufacturer</assignToReference>
            <name>manufacturer</name>
        </outputParameters>
        <outputParameters>
            <assignToReference>varFDANDCCode</assignToReference>
            <name>ndcCode</name>
        </outputParameters>
        <outputParameters>
            <assignToReference>varFDAActiveIngredients</assignToReference>
            <name>activeIngredients</name>
        </outputParameters>
        <outputParameters>
            <assignToReference>varFDAIndicationsAndUsage</assignToReference>
